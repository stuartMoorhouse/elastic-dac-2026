# Copy this file to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars to version control.

# Sensitive values (ec_api_key) must NOT be stored in this file.
# Set them via environment variable before running terraform:
#   export TF_VAR_ec_api_key=<your-key>
# Or add them directly to terraform.tfvars (which is gitignored).

# Target environment for rule deployment: "dev" or "prod"
# Use terraform apply -var="environment=dev" to override on the command line
environment = "dev"

# Elastic Cloud region
# Examples: gcp-europe-north1, aws-eu-west-1, azure-eastus2
region = "gcp-europe-north1"

# Deployment template ID for the chosen region
deployment_template_id = "gcp-storage-optimized"

# Deployment names
deployment_name_dev  = "dac-demo-dev"
deployment_name_prod = "dac-demo-prod"

# Elasticsearch hot tier node size
elasticsearch_size = "8g"
